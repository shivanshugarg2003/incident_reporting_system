{
  "name": "incident-reporting-system",
  "private": true,
  "scripts": {
    "start": "npm run dev --prefix frontend",
    "api": "cd backend && python app.py",
    "dev": "concurrently \"npm run start\" \"npm run api\"",
    "test:e2e": "npm test --prefix playwright",
    "test:backend": "cd backend && python -m pytest tests/ -v --cov=router --cov=app --cov-report=term-missing --cov-fail-under=100"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
